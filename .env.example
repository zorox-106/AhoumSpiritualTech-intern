# Database Credentials
DB_NAME=sessions_db
DB_USER=sessions_user
DB_PASSWORD=sessions_password

# Django Settings
DJANGO_SECRET_KEY=replace-me-with-a-very-secret-key-in-production

# OAuth Credentials (placeholders, replace with actual keys)
